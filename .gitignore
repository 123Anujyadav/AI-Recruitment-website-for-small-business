# ============================================================
# TalentAI MVP — .gitignore
# ============================================================

# ---- Environment variables ----
.env
.env.*
!.env.example

# ---- Virtual environment ----
venv/
env/
ENV/
.venv/

# ---- Python bytecode & packaging ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
pip-log.txt
pip-delete-this-directory.txt
*.whl

# ---- Pytest / Coverage ----
.pytest_cache/
.coverage
htmlcov/
*.cover
*.py,cover

# ---- Type checkers ----
.mypy_cache/
.pytype/

# ---- IDEs / Editors ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ---- Django ----
db.sqlite3
db.sqlite3-journal
*.log
media/
staticfiles/
collected_static/

# ---- OS files ----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
._*

# ---- Secrets & credentials ----
*.pem
*.key

# ---- Planning / AI agent artifacts ----
.planning/
